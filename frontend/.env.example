# ─── API Backend ───────────────────────────────────────────────────────────────
# Dev (emulador): http://127.0.0.1:5001/{projectId}/us-central1/api
# Prod: https://us-central1-{projectId}.cloudfunctions.net/api (o dominio propio via Hosting)
VITE_API_URL=http://127.0.0.1:5001/demo-barberhouse/us-central1/api

# true  → datos mockeados (desarrollo sin backend)
# false → llama al backend real
VITE_USE_MOCKS=true

# ─── Firebase Client SDK ───────────────────────────────────────────────────────
# Obtener desde Firebase Console → Configuración del proyecto → Tus apps → Web
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Solo desarrollo: emulador de Auth ─────────────────────────────────────────
# Descomentá cuando usés el emulador local.
# El Client SDK llama a connectAuthEmulator() con este valor.
# VITE_FIREBASE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099
