rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Turnos / Agenda
    match /turnos/{turnoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || hasRole('barbero');
    }

    // Turnos fijos (recurrentes)
    match /turnosFijos/{turnoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || hasRole('barbero');
    }

    // Equipo (barberos)
    match /barberos/{barberoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Catálogo de servicios
    match /servicios/{servicioId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Inventario de productos
    match /inventario/{productoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || hasRole('cajero');
    }

    // Ventas de productos (dentro de caja)
    match /ventas/{ventaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Caja diaria
    match /caja/{cajaId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || hasRole('cajero');
      allow delete: if isAdmin();
    }

    // Bloquear todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
